---
import { navigationLinks, site } from "../data/site";
import Icon from "./Icons.astro";
---

<nav
  class="fixed left-1/2 top-3 z-50 flex -translate-x-1/2 items-center gap-0.5 whitespace-nowrap rounded-full bg-white px-3 py-2 sm:top-5 sm:gap-1.5 sm:px-7 sm:py-2.5"
  style="box-shadow: 0 8px 32px rgba(0,0,0,0.12), 0 1px 4px rgba(0,0,0,0.06); max-width: calc(100vw - 24px)"
  aria-label="Primary navigation"
>
  {
    navigationLinks.map((link, index) => (
      <a
        href={link.href}
        data-nav-link
        data-section-id={link.sectionId}
        class:list={[
          "flex items-center rounded-full px-2.5 py-1.5 text-xs font-medium text-[#555] no-underline transition-all hover:bg-[#e76f51] hover:text-white sm:px-3.5 sm:text-sm",
          index === 0 && "nav-link-active",
        ]}
      >
        {index === 0 ? (
          <>
            <span class="sm:hidden" aria-hidden="true">
              <Icon name="home" size={15} />
            </span>
            <span class="hidden sm:inline">{link.label}</span>
          </>
        ) : (
          link.label
        )}
      </a>
    ))
  }

  <span class="mx-1 select-none font-light text-[#d0d0d0]">|</span>

  <a
    href={site.github}
    target="_blank"
    rel="me noreferrer"
    aria-label="GitHub"
    class="flex items-center gap-1.5 rounded-full px-2.5 py-1.5 text-xs font-medium text-[#555] no-underline transition-all hover:bg-[#e76f51] hover:text-white sm:px-3 sm:text-sm"
  >
    <Icon name="github" size={18} />
    <span class="hidden sm:inline">GitHub</span>
  </a>
  <a
    href={site.linkedin}
    target="_blank"
    rel="me noreferrer"
    aria-label="LinkedIn"
    class="flex items-center gap-1.5 rounded-full px-2.5 py-1.5 text-xs font-medium text-[#555] no-underline transition-all hover:bg-[#e76f51] hover:text-white sm:px-3 sm:text-sm"
  >
    <Icon name="linkedin" size={18} />
    <span class="hidden sm:inline">LinkedIn</span>
  </a>
</nav>
