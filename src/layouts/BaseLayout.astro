---
import "../styles/global.css";
import { site } from "../data/site";

type Props = {
  title?: string;
  description?: string;
};

const title = Astro.props.title ?? `${site.name} | ${site.title}`;
const description = Astro.props.description ?? site.description;
const canonicalUrl = new URL(Astro.url.pathname, site.url).toString();
const socialImage = new URL(site.socialImage, site.url).toString();
const socialImageWidth = 1200;
const socialImageHeight = 630;
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": `${site.url}/#person`,
      name: site.name,
      givenName: site.firstName,
      familyName: site.lastName,
      url: site.url,
      image: socialImage,
      jobTitle: site.title,
      email: `mailto:${site.email}`,
      knowsAbout: ["React", "TypeScript", "JavaScript", ".NET", "Node.js", "Full-stack development"],
      sameAs: [site.github, site.linkedin],
    },
    {
      "@type": "WebSite",
      "@id": `${site.url}/#website`,
      url: site.url,
      name: `${site.name} Portfolio`,
      description,
      inLanguage: site.language,
      publisher: {
        "@id": `${site.url}/#person`,
      },
    },
    {
      "@type": "ProfilePage",
      "@id": `${canonicalUrl}#webpage`,
      url: canonicalUrl,
      name: title,
      description,
      isPartOf: {
        "@id": `${site.url}/#website`,
      },
      about: {
        "@id": `${site.url}/#person`,
      },
      primaryImageOfPage: {
        "@type": "ImageObject",
        url: socialImage,
        width: socialImageWidth,
        height: socialImageHeight,
      },
      inLanguage: site.language,
    },
  ],
};
---

<!doctype html>
<html lang={site.language}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={site.name} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="me" href={site.github} />
    <link rel="me" href={site.linkedin} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#faf6f0" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content={site.locale} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:secure_url" content={socialImage} />
    <meta property="og:image:type" content={site.socialImageType} />
    <meta property="og:image:width" content={socialImageWidth.toString()} />
    <meta property="og:image:height" content={socialImageHeight.toString()} />
    <meta property="og:image:alt" content={site.socialImageAlt} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content={site.socialImageAlt} />

    <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>
  </head>
  <body>
    <slot />
  </body>
</html>
